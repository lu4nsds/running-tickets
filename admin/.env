# ------------- Env do Admin (Vue 3 + Vite) -------------

# [SOMENTE DESENVOLVIMENTO]
# Porta do servidor de desenvolvimento
VITE_APP_PORT=5174

# URL alvo do proxy Vite (aponta para o backend Laravel)
VITE_API_TARGET=http://localhost:80

# Hosts permitidos pelo servidor de desenvolvimento
VITE_APP_ALLOWED_HOSTS=localhost

# [DESENVOLVIMENTO E PRODUÇÃO]
# URL da API Backend
# Em desenvolvimento, use /api para aproveitar o proxy do Vite (evita CORS)
# Para acessar do celular, substitua pelo IP local: ex: http://192.168.1.100:8000/api
#   Descubra com: ipconfig (IPv4 Address da rede Wi-Fi/Ethernet)
# Em produção, use a URL completa: ex: https://api.runningtickets.com.br/api
VITE_API_URL=/api
