#--------------------------------------------
# [APP]
#--------------------------------------------
APP_NAME="Running Tickets"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

#--------------------------------------------
# [SERVER]
#--------------------------------------------
PHP_CLI_SERVER_WORKERS=4

#--------------------------------------------
# [SECURITY]
#--------------------------------------------
BCRYPT_ROUNDS=12

#--------------------------------------------
# [LOGGING]
#--------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=errorlog
LOG_LEVEL=debug

#--------------------------------------------
# [DATABASE]
#--------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=running_tickets
DB_USERNAME=laravel
DB_PASSWORD=secret

#--------------------------------------------
# [CACHE]
#--------------------------------------------
CACHE_STORE=redis

#--------------------------------------------
# [SESSION]
#--------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

#--------------------------------------------
# [REDIS]
#--------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

#--------------------------------------------
# [QUEUE & BROADCAST]
#--------------------------------------------
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

#--------------------------------------------
# [STORAGE]
#--------------------------------------------
FILESYSTEM_DISK=local

#--------------------------------------------
# [AWS S3]
#--------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#--------------------------------------------
# [MAIL]
# Use Mailtrap ou similar no desenvolvimento: https://mailtrap.io
#--------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@runningtickets.com"
MAIL_FROM_NAME="Running Tickets"
RESEND_API_KEY=

#--------------------------------------------
# [FRONTEND]
#--------------------------------------------
VITE_APP_NAME="${APP_NAME}"
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

#--------------------------------------------
# [CORS]
# Para ngrok, adicione a URL aqui também
#--------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

#--------------------------------------------
# [GOOGLE OAUTH]
# Cadastrar em: https://console.cloud.google.com/
#--------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

#--------------------------------------------
# [MERCADO PAGO]
# Modo "platform" — repasse manual pelo organizador
# Credenciais em: https://www.mercadopago.com.br/developers/
#--------------------------------------------
MERCADOPAGO_SANDBOX_MODE=true
MERCADOPAGO_PLATFORM_ACCESS_TOKEN=
MERCADOPAGO_PLATFORM_PUBLIC_KEY=
