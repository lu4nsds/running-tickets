# ------------- Env do Client -------------

# [SOMENTE DESENVOLVIMENTO]
VITE_APP_PORT=5173
VITE_API_TARGET=http://localhost:8000
VITE_APP_ALLOWED_HOSTS=localhost

# [DESENVOLVIMENTO E PRODUÇÂO]
# URL da API Backend
# Para acessar do celular, substitua localhost pelo IP local do seu PC
# Descubra com: ipconfig (procure IPv4 Address da sua rede Wi-Fi/Ethernet)
# Exemplo: VITE_API_URL=http://192.168.1.100:8000/api
VITE_API_URL=/api
